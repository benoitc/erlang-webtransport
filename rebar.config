{erl_opts, [debug_info, warnings_as_errors]}.

{deps, [
    {erlang_h2, {git, "https://github.com/benoitc/erlang_h2.git", {branch, "main"}}},
    {quic, {git, "https://github.com/benoitc/erlang_quic.git", {branch, "main"}}}
]}.

{profiles, [
    {test, [
        {deps, [
            {proper, "1.4.0"}
        ]}
    ]}
]}.

{cover_enabled, true}.
{cover_opts, [verbose]}.

{project_plugins, [rebar3_ex_doc]}.

{hex, [{doc, ex_doc}]}.

{ex_doc, [
    {source_url, <<"https://github.com/benoitc/erlang-webtransport">>},
    {main, <<"readme">>},
    {extras, [
        <<"README.md">>,
        <<"docs/getting-started.md">>,
        <<"docs/handlers.md">>,
        <<"docs/configuration.md">>,
        <<"docs/integration.md">>
    ]},
    {groups_for_extras, [
        {<<"Guides">>, [
            <<"docs/getting-started.md">>,
            <<"docs/handlers.md">>,
            <<"docs/configuration.md">>,
            <<"docs/integration.md">>
        ]}
    ]},
    {groups_for_modules, [
        {<<"Public API">>, [webtransport, webtransport_handler]},
        {<<"Session">>, [webtransport_session, webtransport_stream]},
        {<<"HTTP/3">>, [webtransport_h3, wt_h3, wt_h3_capsule,
                        webtransport_h3_router]},
        {<<"HTTP/2">>, [webtransport_h2, wt_h2_capsule, wt_h2_init]},
        {<<"Utilities">>, [wt_error, webtransport_client_handler]}
    ]}
]}.
